APP_NAME="SIRPL"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://rplpoliban.my.id
APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning
LOG_SLOW_QUERY_MS=500

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sirpl
DB_USERNAME=sirpl
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.rplpoliban.my.id
SESSION_SECURE_COOKIE=true
SANCTUM_STATEFUL_DOMAINS=rplpoliban.my.id,www.rplpoliban.my.id

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_TIMEOUT=15
MAIL_EHLO_DOMAIN=rplpoliban.my.id
MAIL_FROM_ADDRESS=noreply@rplpoliban.my.id
MAIL_FROM_NAME="SIRPL Poliban"

RETENTION_AUDIT_LOG_DAYS=365
RETENTION_NOTIFICATION_READ_DAYS=90
RETENTION_ARCHIVE_DISK=local

APP_TIMEZONE=Asia/Makassar
